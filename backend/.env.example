PORT=5000

# Base URL (Machine Local IP)
BASE_URL=http://192.168.1.5:5000

# Supabase Configuration
# Use the 'Transaction Pooler' connection string for PostgreSQL (Port 6543)
PG_CONNECTION_STRING=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
SUPABASE_SERVICE_ROLE=[YOUR_SERVICE_ROLE_KEY]

# S3 / MinIO Configuration (Cloud Storage or Self-hosted S3)
# For AWS S3: use MINIO_ENDPOINT=s3.amazonaws.com, MINIO_PORT=443, MINIO_USE_SSL=true
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=[YOUR_S3_ACCESS_KEY]
MINIO_SECRET_KEY=[YOUR_S3_SECRET_KEY]
MINIO_BUCKET=[YOUR_S3_BUCKET_NAME]

# Priority Scoring Weights (FR 4)
PRIORITY_WEIGHT_VISUAL=0.4
PRIORITY_WEIGHT_TEXTUAL=0.3
PRIORITY_WEIGHT_DENSITY=0.2
PRIORITY_WEIGHT_CREDIBILITY=0.1

# AI Fusion (Groq Llama 3)
OPEN_SOURCE_LLM_KEY=[GROQ_API_KEY]
OPEN_SOURCE_LLM_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Hugging Face Space Classifier Configuration
USE_HF_CLASSIFIER=true
HF_SPACE_ID=manthan2876/CivicConnect-Classifier
HF_TOKEN=[YOUR_HF_TOKEN]
